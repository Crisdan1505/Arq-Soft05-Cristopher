@{
    ViewData["Title"] = "Calculadora";
}

<div class="calculator-page">
    <div class="calculator-card">
        <div class="calculator-header">
            <h1>Calculadora API</h1>
            <p>Consume operaciones desde <strong>Calculadora.Api</strong></p>
        </div>

        <form method="post">
            <div class="input-group-custom">
                <label>Número A</label>
                <input type="number" step="any" name="a" placeholder="Ej. 10" required />
            </div>

            <div class="input-group-custom">
                <label>Número B</label>
                <input type="number" step="any" name="b" placeholder="Ej. 5" required />
            </div>

            <div class="input-group-custom">
                <label>Operación</label>
                <select name="operacion">
                    <option value="sumar">Sumar</option>
                    <option value="restar">Restar</option>
                    <option value="multiplicar">Multiplicar</option>
                    <option value="dividir">Dividir</option>
                </select>
            </div>

            <button type="submit" class="btn-calculate">
                Calcular
            </button>
        </form>

        @if (ViewBag.Resultado != null)
        {
            <div class="result-box">
                <span>Resultado</span>
                <h2>@ViewBag.Resultado</h2>
                <p>Operación realizada: <strong>@ViewBag.Operacion</strong></p>
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                <span>Error</span>
                <p>@ViewBag.Error</p>
            </div>
        }
    </div>
</div>

<style>
    .calculator-page {
        min-height: 75vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(-45deg, #0f172a, #312e81, #7c3aed, #06b6d4);
        background-size: 400% 400%;
        animation: fondoAnimado 12s ease infinite;
        border-radius: 24px;
        padding: 40px 20px;
        overflow: hidden;
    }

    .calculator-card {
        width: 100%;
        max-width: 480px;
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 28px;
        padding: 32px;
        color: white;
        box-shadow: 0 25px 80px rgba(0, 0, 0, 0.35);
        animation: aparecer 0.8s ease-out, flotar 4s ease-in-out infinite;
    }

    .calculator-header {
        text-align: center;
        margin-bottom: 28px;
    }

        .calculator-header h1 {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .calculator-header p {
            color: #ddd6fe;
            margin: 0;
        }

    .input-group-custom {
        margin-bottom: 18px;
    }

        .input-group-custom label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #ede9fe;
        }

        .input-group-custom input,
        .input-group-custom select {
            width: 100%;
            padding: 13px 15px;
            border-radius: 14px;
            border: none;
            outline: none;
            font-size: 1rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .input-group-custom input:focus,
            .input-group-custom select:focus {
                transform: scale(1.02);
                box-shadow: 0 0 0 4px rgba(165, 243, 252, 0.35);
            }

    .btn-calculate {
        width: 100%;
        border: none;
        border-radius: 16px;
        padding: 14px;
        margin-top: 8px;
        font-size: 1.1rem;
        font-weight: 700;
        color: white;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        box-shadow: 0 12px 30px rgba(139, 92, 246, 0.45);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .btn-calculate:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 18px 40px rgba(139, 92, 246, 0.6);
        }

        .btn-calculate:active {
            transform: scale(0.97);
        }

    .result-box {
        margin-top: 24px;
        background: rgba(15, 23, 42, 0.75);
        border-radius: 18px;
        padding: 20px;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.18);
        animation: resultadoAparece 0.5s ease-out;
    }

        .result-box span {
            display: block;
            color: #a5f3fc;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .result-box h2 {
            font-size: 3rem;
            font-weight: 900;
            margin: 0;
            color: #ffffff;
            animation: brillo 1s ease-in-out;
        }

        .result-box p {
            margin-top: 10px;
            color: #ddd6fe;
        }

    .error-box {
        margin-top: 24px;
        background: rgba(127, 29, 29, 0.8);
        border-radius: 18px;
        padding: 18px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        animation: resultadoAparece 0.5s ease-out;
    }

        .error-box span {
            display: block;
            color: #fecaca;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .error-box p {
            margin: 0;
            color: white;
        }

    @@keyframes aparecer {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.95);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes flotar {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-8px);
        }
    }

    @@keyframes resultadoAparece {
        from {
            opacity: 0;
            transform: scale(0.8);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes brillo {
        0% {
            transform: scale(0.5);
            opacity: 0;
        }

        50% {
            transform: scale(1.15);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes fondoAnimado {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }
</style>